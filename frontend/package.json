{
  "name": "jleague-bar-graph-frontend",
  "type": "module",
  "scripts": {
    "clean": "rm -rf ../docs/assets ../docs/matches.html ../docs/j_points.html ../docs/tournament.html",
    "dev": "vite",
    "build": "npm run clean && tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:full": "playwright test --grep @full-render"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "happy-dom": "^20.6.3",
    "markdownlint-cli2": "^0.22.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@types/papaparse": "^5.5.2",
    "js-yaml": "^4.1.1",
    "papaparse": "^5.5.3"
  }
}
